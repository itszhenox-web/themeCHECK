{% doc %}
  @prompt
    Add "hide on scroll down, show on scroll up" behavior to the navbar/header. The header should not be sticky by default — it should hide when the user scrolls down, and smoothly slide back into view when the user scrolls back up. Use vanilla JavaScript and CSS transitions (no jQuery). The solution should work with the existing header element and not break any existing theme styles.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-scroll-header-controller-{{ ai_gen_id }} {
    display: block;
  }

  body.ai-header-scroll-enabled-{{ ai_gen_id }} .shopify-section-header-sticky {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    transition: transform {{ block.settings.transition_speed }}ms cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  body.ai-header-scroll-enabled-{{ ai_gen_id }} .shopify-section-header-sticky.ai-header-hidden-{{ ai_gen_id }} {
    transform: translateY(-100%);
  }

  body.ai-header-scroll-enabled-{{ ai_gen_id }} .shopify-section-header-sticky.ai-header-visible-{{ ai_gen_id }} {
    transform: translateY(0);
  }

  body.ai-header-scroll-enabled-{{ ai_gen_id }} header.shopify-section-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    transition: transform {{ block.settings.transition_speed }}ms cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  body.ai-header-scroll-enabled-{{ ai_gen_id }} header.shopify-section-header.ai-header-hidden-{{ ai_gen_id }} {
    transform: translateY(-100%);
  }

  body.ai-header-scroll-enabled-{{ ai_gen_id }} header.shopify-section-header.ai-header-visible-{{ ai_gen_id }} {
    transform: translateY(0);
  }

  body.ai-header-scroll-enabled-{{ ai_gen_id }} .header-wrapper {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    transition: transform {{ block.settings.transition_speed }}ms cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  body.ai-header-scroll-enabled-{{ ai_gen_id }} .header-wrapper.ai-header-hidden-{{ ai_gen_id }} {
    transform: translateY(-100%);
  }

  body.ai-header-scroll-enabled-{{ ai_gen_id }} .header-wrapper.ai-header-visible-{{ ai_gen_id }} {
    transform: translateY(0);
  }

  body.ai-header-scroll-enabled-{{ ai_gen_id }} .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    transition: transform {{ block.settings.transition_speed }}ms cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  body.ai-header-scroll-enabled-{{ ai_gen_id }} .header.ai-header-hidden-{{ ai_gen_id }} {
    transform: translateY(-100%);
  }

  body.ai-header-scroll-enabled-{{ ai_gen_id }} .header.ai-header-visible-{{ ai_gen_id }} {
    transform: translateY(0);
  }

  body.ai-header-scroll-enabled-{{ ai_gen_id }} {
    padding-top: var(--ai-header-height-{{ ai_gen_id }}, 0);
  }
{% endstyle %}

<scroll-header-{{ ai_gen_id }} class="ai-scroll-header-controller-{{ ai_gen_id }}" {{ block.shopify_attributes }}></scroll-header-{{ ai_gen_id }}>

<script>
  (function() {
    class ScrollHeader{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.lastScrollY = 0;
        this.ticking = false;
        this.scrollThreshold = {{ block.settings.scroll_threshold }};
        this.header = null;
        this.headerHeight = 0;
      }

      connectedCallback() {
        this.findHeader();
        if (this.header) {
          this.init();
        }
      }

      findHeader() {
        const selectors = [
          '.shopify-section-header-sticky',
          'header.shopify-section-header',
          '.header-wrapper',
          '.header',
          'header'
        ];

        for (const selector of selectors) {
          const element = document.querySelector(selector);
          if (element) {
            this.header = element;
            break;
          }
        }
      }

      init() {
        document.body.classList.add('ai-header-scroll-enabled-{{ ai_gen_id }}');
        
        this.measureHeader();
        this.header.classList.add('ai-header-visible-{{ ai_gen_id }}');
        
        window.addEventListener('scroll', this.handleScroll.bind(this), { passive: true });
        window.addEventListener('resize', this.handleResize.bind(this), { passive: true });
      }

      measureHeader() {
        this.headerHeight = this.header.offsetHeight;
        document.documentElement.style.setProperty(
          '--ai-header-height-{{ ai_gen_id }}',
          this.headerHeight + 'px'
        );
      }

      handleResize() {
        this.measureHeader();
      }

      handleScroll() {
        if (!this.ticking) {
          window.requestAnimationFrame(() => {
            this.updateHeader();
            this.ticking = false;
          });
          this.ticking = true;
        }
      }

      updateHeader() {
        const currentScrollY = window.pageYOffset || document.documentElement.scrollTop;
        
        if (currentScrollY < this.scrollThreshold) {
          this.showHeader();
          this.lastScrollY = currentScrollY;
          return;
        }

        if (currentScrollY > this.lastScrollY && currentScrollY > this.scrollThreshold) {
          this.hideHeader();
        } else if (currentScrollY < this.lastScrollY) {
          this.showHeader();
        }

        this.lastScrollY = currentScrollY;
      }

      hideHeader() {
        this.header.classList.remove('ai-header-visible-{{ ai_gen_id }}');
        this.header.classList.add('ai-header-hidden-{{ ai_gen_id }}');
      }

      showHeader() {
        this.header.classList.remove('ai-header-hidden-{{ ai_gen_id }}');
        this.header.classList.add('ai-header-visible-{{ ai_gen_id }}');
      }

      disconnectedCallback() {
        window.removeEventListener('scroll', this.handleScroll.bind(this));
        window.removeEventListener('resize', this.handleResize.bind(this));
        document.body.classList.remove('ai-header-scroll-enabled-{{ ai_gen_id }}');
        if (this.header) {
          this.header.classList.remove('ai-header-hidden-{{ ai_gen_id }}', 'ai-header-visible-{{ ai_gen_id }}');
        }
      }
    }

    customElements.define('scroll-header-{{ ai_gen_id }}', ScrollHeader{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Hide header on scroll",
  "settings": [
    {
      "type": "header",
      "content": "Scroll behavior"
    },
    {
      "type": "range",
      "id": "scroll_threshold",
      "label": "Scroll threshold",
      "info": "Distance in pixels before header starts hiding",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "transition_speed",
      "label": "Transition speed",
      "min": 100,
      "max": 800,
      "step": 50,
      "unit": "ms",
      "default": 300
    }
  ],
  "presets": [
    {
      "name": "Hide header on scroll"
    }
  ]
}
{% endschema %}
