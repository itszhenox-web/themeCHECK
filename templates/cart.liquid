<div class="cart-page">
  <h1>Your Cart</h1>
  {% if cart.item_count > 0 %}
    <form action="/cart" method="post">
      <table class="cart-table">
        <thead>
          <tr>
            <th>Product</th>
            <th>Price</th>
            <th>Quantity</th>
            <th>Total</th>
          </tr>
        </thead>
        <tbody>
          {% for item in cart.items %}
            <tr>
              <td><a href="{{ item.url }}">{{ item.title }}</a></td>
              <td>{{ item.price | money }}</td>
              <td><input type="number" name="updates[]" value="{{ item.quantity }}" min="1"></td>
              <td>{{ item.total_price | money }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
      <button type="submit" class="btn btn-secondary">Update Cart</button>
    </form>
    <div class="cart-summary">
      <p class="cart-total">Subtotal: <strong>{{ cart.total_price | money }}</strong></p>
      <p class="cart-note">Shipping and taxes calculated at checkout</p>
      <a href="/checkout" class="btn btn-primary btn-large">Proceed to Checkout</a>
    </div>
  {% else %}
    <p>Your cart is empty</p>
    <a href="/collections/all" class="btn btn-primary">Continue Shopping</a>
  {% endif %}
</div>