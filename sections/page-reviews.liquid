<section class="page-hero" style="height:40vh;min-height:280px;">
  <div class="page-hero__bg">
    <div class="page-hero__bg-placeholder"></div>
    <div class="page-hero__overlay"></div>
  </div>
  <div class="container">
    <div class="page-hero__content" style="text-align:center;width:100%;">
      <p class="eyebrow" style="margin-bottom:1rem;">— 2,847+ Five-Star Reviews</p>
      <h1 style="font-family:var(--font-serif);font-size:clamp(2.5rem,6vw,5rem);color:var(--white);">Evidence of <em style="font-style:italic;color:rgba(209,209,209,0.45);">Love</em></h1>
    </div>
  </div>
</section>
<section class="page-body">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr;gap:1rem;max-width:48rem;">
      {% for block in section.blocks %}
        <div class="review-card" {{ block.shopify_attributes }}>
          <div class="review-card__stars">
            {% for i in (1..5) %}<svg viewBox="0 0 24 24" width="12" height="12"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" fill="currentColor"/></svg>{% endfor %}
          </div>
          <p class="review-card__quote">"{{ block.settings.review_text }}"</p>
          <div class="review-card__footer">
            <div>
              <p class="review-card__author">{{ block.settings.author }}</p>
              <p class="review-card__loc">{{ block.settings.location }}</p>
            </div>
            <span class="review-card__verified">✓ Verified</span>
          </div>
        </div>
      {% endfor %}
    </div>
    <div style="margin-top:3rem;">
      <a href="/collections/all" class="btn-primary">Shop the Collection</a>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Reviews Page",
  "blocks": [{"type":"review","name":"Review","settings":[
    {"type":"text","id":"author","label":"Author","default":"Sarah M."},
    {"type":"text","id":"location","label":"Location","default":"New York, USA"},
    {"type":"textarea","id":"review_text","label":"Review Text","default":"These bracelets made the distance feel so much smaller."}
  ]}],
  "presets": [{"name":"Reviews Page","blocks":[
    {"type":"review","settings":{"author":"Sarah & Marcus","location":"New York ↔ London","review_text":"We've been long distance for 2 years. These bracelets make me feel like he's right here. I look at my wrist and smile every single day."}},
    {"type":"review","settings":{"author":"Emma J.","location":"Portland, OR","review_text":"I bought this for my boyfriend's birthday. He literally teared up. Best gift I've ever given anyone. The quality is stunning."}},
    {"type":"review","settings":{"author":"Alex & Jordan","location":"Toronto ↔ Melbourne","review_text":"13,000 miles apart but these bracelets close the gap. We never take them off. It's our silent way of saying I'm thinking of you."}},
    {"type":"review","settings":{"author":"Mia R.","location":"Chicago, IL","review_text":"The quality is insane for the price. I shower with it, sleep with it — still looks perfect after 6 months."}},
    {"type":"review","settings":{"author":"Aisha K.","location":"Dubai, UAE","review_text":"The handwritten note that came with our set made me cry. You can feel the love in every detail. Absolutely worth every penny."}}
  ]}]
}
{% endschema %}