<section class="trust-strip">
  <div class="container">
    <div class="trust-strip__grid">
      <div class="trust-item"><p class="trust-item__label">{{ section.settings.item_1_label | default: 'Free Shipping' }}</p><p class="trust-item__sub">{{ section.settings.item_1_sub | default: 'On every order, worldwide' }}</p></div>
      <div class="trust-item"><p class="trust-item__label">{{ section.settings.item_2_label | default: '30-Day Returns' }}</p><p class="trust-item__sub">{{ section.settings.item_2_sub | default: 'No questions asked' }}</p></div>
      <div class="trust-item"><p class="trust-item__label">{{ section.settings.item_3_label | default: 'Ships in 24h' }}</p><p class="trust-item__sub">{{ section.settings.item_3_sub | default: 'Express options available' }}</p></div>
      <div class="trust-item"><p class="trust-item__label">{{ section.settings.item_4_label | default: 'Secure Checkout' }}</p><p class="trust-item__sub">{{ section.settings.item_4_sub | default: '256-bit SSL encryption' }}</p></div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Trust Strip",
  "settings": [
    {"type":"text","id":"item_1_label","label":"Item 1 Heading","default":"Free Shipping"},
    {"type":"text","id":"item_1_sub","label":"Item 1 Subtext","default":"On every order, worldwide"},
    {"type":"text","id":"item_2_label","label":"Item 2 Heading","default":"30-Day Returns"},
    {"type":"text","id":"item_2_sub","label":"Item 2 Subtext","default":"No questions asked"},
    {"type":"text","id":"item_3_label","label":"Item 3 Heading","default":"Ships in 24h"},
    {"type":"text","id":"item_3_sub","label":"Item 3 Subtext","default":"Express options available"},
    {"type":"text","id":"item_4_label","label":"Item 4 Heading","default":"Secure Checkout"},
    {"type":"text","id":"item_4_sub","label":"Item 4 Subtext","default":"256-bit SSL encryption"}
  ]
}
{% endschema %}