<section class="trust-section">
  <div class="container">
    <div class="trust-grid">
      {%- for i in (1..4) -%}
        {%- assign icon_key = 'icon_' | append: i -%}
        {%- assign label_key = 'label_' | append: i -%}
        {%- assign sub_key = 'sub_' | append: i -%}
        <div class="trust-item">
          <div class="trust-icon">{{ section.settings[icon_key] }}</div>
          <div>
            <p class="trust-label">{{ section.settings[label_key] }}</p>
            <p class="trust-sub">{{ section.settings[sub_key] }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Trust Badges",
  "settings": [
    {"type":"text","id":"icon_1","label":"Icon 1","default":"🔒"},
    {"type":"text","id":"label_1","label":"Label 1","default":"Secure Checkout"},
    {"type":"text","id":"sub_1","label":"Subtext 1","default":"256-bit SSL encryption"},
    {"type":"text","id":"icon_2","label":"Icon 2","default":"↩"},
    {"type":"text","id":"label_2","label":"Label 2","default":"30-Day Returns"},
    {"type":"text","id":"sub_2","label":"Subtext 2","default":"No questions asked"},
    {"type":"text","id":"icon_3","label":"Icon 3","default":"✈"},
    {"type":"text","id":"label_3","label":"Label 3","default":"Free Shipping"},
    {"type":"text","id":"sub_3","label":"Subtext 3","default":"On every order, worldwide"},
    {"type":"text","id":"icon_4","label":"Icon 4","default":"♥"},
    {"type":"text","id":"label_4","label":"Label 4","default":"50,000+ Couples"},
    {"type":"text","id":"sub_4","label":"Subtext 4","default":"Trust Radioactive Love"}
  ]
}
{% endschema %}