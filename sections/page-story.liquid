<section style="position:relative;height:70vh;overflow:hidden;display:flex;align-items:center;">
  <div style="position:absolute;inset:0;">
    {% if section.settings.hero_image != blank %}<img src="{{ section.settings.hero_image | img_url: '1920x' }}" alt="" style="width:100%;height:100%;object-fit:cover;">{% else %}<div style="width:100%;height:100%;background:linear-gradient(135deg,#1a0000,#0a0a0a);"></div>{% endif %}
    <div style="position:absolute;inset:0;background:rgba(10,10,10,0.7);"></div>
  </div>
  <div class="container" style="position:relative;">
    <h1 style="font-family:var(--font-serif);font-size:clamp(3rem,8vw,6rem);color:var(--white);">Our Story</h1>
  </div>
</section>
<section style="padding:5rem 0 8rem;">
  <div class="container">
    <div style="display:grid;gap:3rem;">
      <div>
        <p style="font-family:var(--font-sans);font-size:0.9375rem;color:rgba(209,209,209,0.5);line-height:1.9;margin-bottom:1.25rem;">Radioactive Love was born in 2019 from a long-distance relationship between two people who refused to let miles define their love.</p>
        <p style="font-family:var(--font-sans);font-size:0.9375rem;color:rgba(209,209,209,0.5);line-height:1.9;margin-bottom:1.25rem;">So we made our own.</p>
        <blockquote style="font-family:var(--font-serif);font-size:1.5rem;color:var(--white);font-style:italic;line-height:1.5;border-left:2px solid var(--glow);padding-left:1.5rem;margin:2.5rem 0;">"Love doesn't weaken over distance — it intensifies. Like radiation, it's invisible but undeniable."</blockquote>
        <p style="font-family:var(--font-sans);font-size:0.9375rem;color:rgba(209,209,209,0.5);line-height:1.9;">Today, Radioactive Love ships to over 50 countries. Every piece is still made with that original intention.</p>
      </div>
    </div>
    <div style="text-align:center;margin-top:4rem;">
      <a href="/collections/all" class="btn-primary">Shop the Collection</a>
    </div>
  </div>
</section>
{% schema %}{"name":"Story Page","settings":[{"type":"image_picker","id":"hero_image","label":"Hero Image"}]}{% endschema %}