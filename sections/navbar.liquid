<nav class="navbar" id="navbar">
  <div class="container">
    <div class="navbar__inner">
      <div class="navbar__links">
        {% if section.settings.link_1_label != blank %}<a href="{{ section.settings.link_1_url }}">{{ section.settings.link_1_label }}</a>{% endif %}
        {% if section.settings.link_2_label != blank %}<a href="{{ section.settings.link_2_url }}">{{ section.settings.link_2_label }}</a>{% endif %}
        {% if section.settings.link_3_label != blank %}<a href="{{ section.settings.link_3_url }}">{{ section.settings.link_3_label }}</a>{% endif %}
      </div>
      <a href="{{ routes.root_url }}" class="navbar__logo">{{ section.settings.logo_text | default: shop.name }}</a>
      <div class="navbar__right">
        <div class="navbar__links" style="margin-left:0;">
          {% if section.settings.link_4_label != blank %}<a href="{{ section.settings.link_4_url }}">{{ section.settings.link_4_label }}</a>{% endif %}
          {% if section.settings.link_5_label != blank %}<a href="{{ section.settings.link_5_url }}">{{ section.settings.link_5_label }}</a>{% endif %}
        </div>
        {% if section.settings.show_search %}
        <a href="{{ routes.search_url }}" class="navbar__icon-btn" aria-label="Search">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </a>
        {% endif %}
        <a href="{{ routes.cart_url }}" class="navbar__icon-btn navbar__cart-wrap" aria-label="Cart">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          {% if cart.item_count > 0 %}<span class="navbar__cart-count">{{ cart.item_count }}</span>{% endif %}
        </a>
        {% if section.settings.show_account %}
        <a href="{{ routes.account_url }}" class="navbar__icon-btn" aria-label="Account">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </a>
        {% endif %}
        <button class="navbar__burger" aria-label="Menu">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
      </div>
    </div>
  </div>
</nav>
<div class="mobile-nav" id="mobile-nav">
  <button class="mobile-nav__close" style="position:absolute;top:1.5rem;right:1.5rem;background:none;border:none;cursor:pointer;color:var(--fg-muted);">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>
  {% if section.settings.link_1_label != blank %}<a href="{{ section.settings.link_1_url }}">{{ section.settings.link_1_label }}</a>{% endif %}
  {% if section.settings.link_2_label != blank %}<a href="{{ section.settings.link_2_url }}">{{ section.settings.link_2_label }}</a>{% endif %}
  {% if section.settings.link_3_label != blank %}<a href="{{ section.settings.link_3_url }}">{{ section.settings.link_3_label }}</a>{% endif %}
  {% if section.settings.link_4_label != blank %}<a href="{{ section.settings.link_4_url }}">{{ section.settings.link_4_label }}</a>{% endif %}
  {% if section.settings.link_5_label != blank %}<a href="{{ section.settings.link_5_url }}">{{ section.settings.link_5_label }}</a>{% endif %}
  <a href="{{ routes.cart_url }}">Cart ({{ cart.item_count }})</a>
</div>
{% schema %}
{
  "name": "Navbar",
  "settings": [
    {"type":"header","content":"Logo"},
    {"type":"text","id":"logo_text","label":"Logo text","default":"Radioactive Love"},
    {"type":"header","content":"Left Links"},
    {"type":"text","id":"link_1_label","label":"Link 1 Label","default":"Home"},
    {"type":"url","id":"link_1_url","label":"Link 1 URL","default":"/"},
    {"type":"text","id":"link_2_label","label":"Link 2 Label","default":"All Products"},
    {"type":"url","id":"link_2_url","label":"Link 2 URL","default":"/collections/all"},
    {"type":"text","id":"link_3_label","label":"Link 3 Label","default":"Gifts & Charms"},
    {"type":"url","id":"link_3_url","label":"Link 3 URL","default":"/collections/mini-gifts-charms"},
    {"type":"header","content":"Right Links"},
    {"type":"text","id":"link_4_label","label":"Link 4 Label","default":"Jewelry"},
    {"type":"url","id":"link_4_url","label":"Link 4 URL","default":"/collections/jewelry-accessories"},
    {"type":"text","id":"link_5_label","label":"Link 5 Label","default":"Story"},
    {"type":"url","id":"link_5_url","label":"Link 5 URL","default":"/pages/story"},
    {"type":"header","content":"Icons"},
    {"type":"checkbox","id":"show_search","label":"Show search icon","default":true},
    {"type":"checkbox","id":"show_account","label":"Show account icon","default":true}
  ]
}
{% endschema %}