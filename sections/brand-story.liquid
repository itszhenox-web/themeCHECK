<section class="brand-story" id="story">
  <div class="brand-story-bg">
    {%- if section.settings.bg_image != blank -%}
      <img src="{{ section.settings.bg_image | img_url: '1800x' }}" alt="" loading="lazy">
    {%- endif -%}
    <div class="brand-story-overlay"></div>
  </div>
  <div class="container">
    <div class="brand-story-content">
      <p class="eyebrow">{{ section.settings.eyebrow | default: '— Why We Exist' }}</p>
      <h2 class="brand-story-title">{{ section.settings.title | default: 'Love is the most radioactive force in the universe.' }}</h2>
      <p class="brand-story-text">{{ section.settings.body | default: 'It started with a goodbye at an airport gate. Two people, one love, 4,000 miles between them. That night, Radioactive Love was born — a physical reminder that real connection doesn't weaken over distance. It intensifies.' }}</p>
      <a href="{{ section.settings.link_url | default: '/pages/about' }}" class="btn btn-ghost">
        {{ section.settings.link_text | default: 'Read Our Full Story' }}
      </a>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Brand Story",
  "settings": [
    {"type":"image_picker","id":"bg_image","label":"Background image"},
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"— Why We Exist"},
    {"type":"text","id":"title","label":"Title","default":"Love is the most radioactive force in the universe."},
    {"type":"textarea","id":"body","label":"Story text"},
    {"type":"text","id":"link_text","label":"Link text","default":"Read Our Full Story"},
    {"type":"url","id":"link_url","label":"Link URL","default":"/pages/about"}
  ]
}
{% endschema %}