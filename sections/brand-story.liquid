<section class="brand-story">
  <div class="brand-story__bg">
    {% if section.settings.bg_image != blank %}
      <img src="{{ section.settings.bg_image | img_url: '1920x' }}" alt="">
    {% endif %}
    <div class="brand-story__overlay"></div>
  </div>
  <div class="container">
    <div class="brand-story__content">
      <p class="eyebrow">— Our Origin</p>
      <h2 class="brand-story__title">Born from a love<br><em>that refused distance.</em></h2>
      <p class="brand-story__text">Radioactive Love started with a single truth: love doesn't weaken over distance — it intensifies. Like radiation, it's invisible but undeniable. Every piece we make is a physical manifestation of that invisible bond.</p>
      <a href="/pages/story" class="brand-story__link">
        <span class="brand-story__link-line"></span>
        Read Our Full Story
      </a>
    </div>
  </div>
</section>
{% schema %}{"name":"Brand Story","settings":[{"type":"image_picker","id":"bg_image","label":"Background Image"}]}{% endschema %}