<section class="collection-section">
  <div class="container">
    <div class="section-header">
      <p class="eyebrow">{{ section.settings.eyebrow | default: '— The Collection' }}</p>
      <h2 class="section-title">{{ section.settings.title | default: 'Find Your Connection' }}</h2>
    </div>
    {%- assign preview_collection = collections[section.settings.collection] -%}
    {%- if preview_collection == empty -%}{%- assign preview_collection = collections.all -%}{%- endif -%}
    <div class="product-grid">
      {%- for product in preview_collection.products limit: section.settings.products_to_show -%}
        <a href="{{ product.url }}" class="product-card">
          <div class="product-card-media">
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | img_url: '700x' }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy">
            {%- else -%}
              <div class="product-card-placeholder"></div>
            {%- endif -%}
            {%- if product.compare_at_price > product.price -%}
              <span class="product-badge">Sale</span>
            {%- elsif forloop.first -%}
              <span class="product-badge">Bestseller</span>
            {%- endif -%}
          </div>
          <div class="product-card-body">
            {%- if product.vendor != blank -%}<p class="product-vendor">{{ product.vendor }}</p>{%- endif -%}
            <h3 class="product-title">{{ product.title }}</h3>
            <div class="product-price">
              <span class="price-current">{{ product.price | money }}</span>
              {%- if product.compare_at_price > product.price -%}
                <span class="price-compare">{{ product.compare_at_price | money }}</span>
              {%- endif -%}
            </div>
          </div>
        </a>
      {%- endfor -%}
    </div>
    <div class="section-cta">
      <a href="{{ section.settings.collection | prepend: '/collections/' | default: routes.collections_url }}" class="btn btn-ghost">
        {{ section.settings.view_all_text | default: 'View All Products' }}
      </a>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Collection Preview",
  "settings": [
    {"type":"collection","id":"collection","label":"Collection"},
    {"type":"range","id":"products_to_show","min":2,"max":8,"step":2,"default":4,"label":"Products to show"},
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"— The Collection"},
    {"type":"text","id":"title","label":"Title","default":"Find Your Connection"},
    {"type":"text","id":"view_all_text","label":"View all button text","default":"View All Products"}
  ]
}
{% endschema %}