<section class="cta-banner">
  <div class="cta-banner__glow"></div>
  <div class="container" style="position:relative;">
    <h2 class="cta-banner__title">Make the<br><em>connection</em> real.</h2>
    <p class="cta-banner__sub">Every bracelet set ships with a handwritten note. Because the details matter.</p>
    <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="btn-primary">{{ section.settings.cta_text | default: 'Shop Now' }}</a>
    <p class="cta-banner__note">Limited batch — <span>50% off</span> ends soon</p>
  </div>
</section>
{% schema %}{"name":"CTA Banner","settings":[{"type":"url","id":"cta_url","label":"CTA URL"},{"type":"text","id":"cta_text","label":"CTA Text","default":"Shop Now"}]}{% endschema %}