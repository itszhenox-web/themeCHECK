<section class="gallery">
  <div class="container">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:1.5rem;" class="gallery__header">
      <div>
        <p class="eyebrow">— Evidence of Love</p>
        <h2 class="gallery__title">Real couples. <em>Real connections.</em></h2>
      </div>
      <div class="gallery__nav">
        <button class="gallery__nav-btn gallery__nav-btn--prev" aria-label="Previous">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button class="gallery__nav-btn gallery__nav-btn--next" aria-label="Next">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
    </div>
    <div class="gallery__scroll" id="gallery-scroll">
      {% for block in section.blocks %}
        <div class="gallery-card" {{ block.shopify_attributes }}>
          {% if block.settings.photo != blank %}
            <img class="gallery-card__img" src="{{ block.settings.photo | img_url: '500x' }}" alt="{{ block.settings.name }}">
          {% else %}
            <div class="gallery-card__img-placeholder"></div>
          {% endif %}
          <p class="gallery-card__quote">"{{ block.settings.review_text }}"</p>
          <div class="gallery-card__meta">
            <span class="gallery-card__name">{{ block.settings.name }}</span>
            <span class="gallery-card__loc">{{ block.settings.location }}</span>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Social Proof Gallery",
  "blocks": [{"type":"review","name":"Review","settings":[
    {"type":"image_picker","id":"photo","label":"Customer Photo"},
    {"type":"text","id":"name","label":"Name","default":"Sarah & Marcus"},
    {"type":"text","id":"location","label":"Location","default":"New York ↔ London"},
    {"type":"textarea","id":"review_text","label":"Review","default":"These bracelets make me feel like he's right here."}
  ]}],
  "presets": [{"name":"Social Proof Gallery","blocks":[
    {"type":"review","settings":{"name":"Sarah & Marcus","location":"New York ↔ London","review_text":"We've been long distance for 2 years. These bracelets make me feel like he's right here. I look at my wrist and smile every single day."}},
    {"type":"review","settings":{"name":"Emma J.","location":"Portland, OR","review_text":"I bought this for my boyfriend's birthday. He literally teared up. Best gift I've ever given anyone."}},
    {"type":"review","settings":{"name":"Alex & Jordan","location":"Toronto ↔ Melbourne","review_text":"13,000 miles apart but these bracelets close the gap. We never take them off."}},
    {"type":"review","settings":{"name":"Mia R.","location":"Chicago, IL","review_text":"The quality is insane for the price. I shower with it, sleep with it — still looks perfect after 6 months."}}
  ]}]
}
{% endschema %}