<section class="winner">
  <div class="container">
    <div class="winner__grid">
      <div>
        {% if section.settings.product_image != blank %}
          <img src="{{ section.settings.product_image | img_url: '800x' }}" alt="{{ section.settings.title }}" style="width:100%;aspect-ratio:4/5;object-fit:cover;">
        {% else %}
          <div style="width:100%;aspect-ratio:4/5;background:var(--bg-card);"></div>
        {% endif %}
      </div>
      <div>
        <p style="font-family:var(--font-sans);font-size:0.65rem;letter-spacing:0.4em;text-transform:uppercase;color:var(--glow);margin-bottom:1.5rem;">— Winner Product</p>
        <h2 class="winner__title">{{ section.settings.title | default: 'Sun & Moon Connection Set' }}</h2>
        <div class="winner__stars">
          {% for i in (1..5) %}<svg width="14" height="14" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" fill="currentColor"/></svg>{% endfor %}
          <span>4.9 · 2,847 reviews</span>
        </div>
        <p style="font-family:var(--font-sans);font-size:0.875rem;color:rgba(209,209,209,0.5);line-height:1.8;margin-bottom:2rem;">{{ section.settings.description | default: 'Two bracelets. One unbreakable bond.' }}</p>
        <div style="display:flex;align-items:baseline;gap:1rem;margin-bottom:2rem;">
          <span class="winner__price-current">{{ section.settings.price | default: '$39.99' }}</span>
          {% if section.settings.compare_price != blank %}<span class="winner__price-old">{{ section.settings.compare_price }}</span>{% endif %}
          <span class="winner__price-save">Save 50%</span>
        </div>
        <a href="{{ section.settings.buy_url | default: '/collections/all' }}" class="btn-primary">Shop Now</a>
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Winner Product",
  "settings": [
    {"type":"image_picker","id":"product_image","label":"Product Image"},
    {"type":"text","id":"title","label":"Title","default":"Sun & Moon Connection Set"},
    {"type":"textarea","id":"description","label":"Description"},
    {"type":"text","id":"price","label":"Price","default":"$39.99"},
    {"type":"text","id":"compare_price","label":"Compare At Price","default":"$79.99"},
    {"type":"url","id":"buy_url","label":"Buy URL"}
  ]
}
{% endschema %}