<section class="winner">
  <div class="container">
    <div class="winner__grid">
      <div class="winner__img-wrap">
        {% if section.settings.product_image != blank %}
          <img src="{{ section.settings.product_image | img_url: '900x' }}" alt="{{ section.settings.title }}">
        {% else %}
          <div style="width:100%;aspect-ratio:4/5;background:var(--bg-card);"></div>
        {% endif %}
        <span class="winner__img-badge">{{ section.settings.badge | default: 'Bestseller' }}</span>
      </div>
      <div>
        <p class="eyebrow winner__eyebrow">{{ section.settings.eyebrow | default: '— Featured Connection' }}</p>
        <h2 class="winner__title">{{ section.settings.title | default: 'Sun & Moon Connection Bracelet Set' }}</h2>
        <p class="winner__subtitle">{{ section.settings.subtitle | default: '"A reminder of your person every day"' }}</p>
        <div class="winner__stars">
          {% for i in (1..5) %}<svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>{% endfor %}
          <span>4.9 · 2,847 reviews</span>
        </div>
        <p class="winner__desc">{{ section.settings.description | default: 'Two bracelets. One unbreakable bond. Surgical-grade stainless steel, 100% waterproof, adjustable to any wrist size. Comes in a premium gift box with a handwritten note.' }}</p>
        {% if section.settings.feature_1 != blank or section.settings.feature_2 != blank or section.settings.feature_3 != blank %}
        <div class="winner__features">
          {% if section.settings.feature_1 != blank %}<div class="winner__feature"><span class="winner__feature-dot"></span>{{ section.settings.feature_1 }}</div>{% endif %}
          {% if section.settings.feature_2 != blank %}<div class="winner__feature"><span class="winner__feature-dot"></span>{{ section.settings.feature_2 }}</div>{% endif %}
          {% if section.settings.feature_3 != blank %}<div class="winner__feature"><span class="winner__feature-dot"></span>{{ section.settings.feature_3 }}</div>{% endif %}
        </div>
        {% endif %}
        <div class="winner__price">
          <span class="winner__price-current">{{ section.settings.price | default: '$39.99' }}</span>
          {% if section.settings.compare_price != blank %}<span class="winner__price-old">{{ section.settings.compare_price }}</span>{% endif %}
          <span class="winner__price-save">{{ section.settings.save_label | default: 'Save 50%' }}</span>
        </div>
        <div class="winner__urgency">
          <span class="winner__urgency-dot"></span>
          <p>Current batch: <span>{{ section.settings.stock | default: '12 sets' }}</span> remaining for next-day dispatch</p>
        </div>
        <a href="{{ section.settings.buy_url | default: '/collections/all' }}" class="btn-primary">{{ section.settings.cta | default: 'Shop Now' }}</a>
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Winner Product",
  "settings": [
    {"type":"image_picker","id":"product_image","label":"Product Image"},
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"— Featured Connection"},
    {"type":"text","id":"title","label":"Title","default":"Sun & Moon Connection Bracelet Set"},
    {"type":"text","id":"subtitle","label":"Subtitle (italic)","default":"A reminder of your person every day"},
    {"type":"textarea","id":"description","label":"Description"},
    {"type":"text","id":"feature_1","label":"Feature 1","default":"Set of 2 bracelets (Sun & Moon)"},
    {"type":"text","id":"feature_2","label":"Feature 2","default":"Surgical-grade stainless steel · 100% waterproof"},
    {"type":"text","id":"feature_3","label":"Feature 3","default":"Premium gift box + handwritten note included"},
    {"type":"text","id":"price","label":"Price","default":"$39.99"},
    {"type":"text","id":"compare_price","label":"Compare At Price","default":"$79.99"},
    {"type":"text","id":"save_label","label":"Save Label","default":"Save 50%"},
    {"type":"text","id":"stock","label":"Stock Urgency Text","default":"12 sets"},
    {"type":"text","id":"cta","label":"CTA Text","default":"Shop Now"},
    {"type":"url","id":"buy_url","label":"Buy URL"},
    {"type":"text","id":"badge","label":"Image Badge","default":"Bestseller"}
  ]
}
{% endschema %}