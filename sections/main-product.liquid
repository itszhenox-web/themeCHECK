<section style="padding:8rem 0 6rem;">
  <div class="container">
    <div class="winner__grid">
      <div>
        {% assign featured_media = product.selected_or_first_available_variant.featured_media | default: product.featured_media %}
        <img id="main-product-img" src="{{ featured_media | img_url: '900x' }}" alt="{{ featured_media.alt | escape }}" style="width:100%;aspect-ratio:1;object-fit:cover;margin-bottom:1rem;">
        <div style="display:flex;gap:0.75rem;overflow-x:auto;">
          {% for media in product.media %}
            <button onclick="document.getElementById('main-product-img').src='{{ media | img_url: '900x' }}'" style="flex-shrink:0;width:5rem;height:5rem;border:1px solid var(--border);background:none;cursor:pointer;overflow:hidden;padding:0;">
              <img src="{{ media | img_url: '200x' }}" alt="" style="width:100%;height:100%;object-fit:cover;">
            </button>
          {% endfor %}
        </div>
      </div>
      <div>
        <p style="font-family:var(--font-sans);font-size:0.65rem;letter-spacing:0.4em;text-transform:uppercase;color:var(--glow);margin-bottom:1rem;">{{ product.type }}</p>
        <h1 style="font-family:var(--font-serif);font-size:clamp(1.75rem,3vw,2.5rem);color:var(--white);margin-bottom:1.5rem;">{{ product.title }}</h1>
        <div style="display:flex;align-items:baseline;gap:1rem;margin-bottom:2rem;">
          <span class="winner__price-current">{{ product.price | money }}</span>
          {% if product.compare_at_price > product.price %}<span class="winner__price-old">{{ product.compare_at_price | money }}</span>{% endif %}
        </div>
        <div style="font-family:var(--font-sans);font-size:0.875rem;color:rgba(209,209,209,0.5);line-height:1.8;margin-bottom:2rem;">{{ product.description }}</div>
        {% form 'product', product %}
          {% if product.has_only_default_variant == false %}
            {% for option in product.options_with_values %}
              <div style="margin-bottom:1rem;">
                <label style="font-family:var(--font-sans);font-size:0.7rem;letter-spacing:0.1em;color:var(--fg-muted);text-transform:uppercase;display:block;margin-bottom:0.5rem;">{{ option.name }}</label>
                <select name="options[{{ option.name }}]" style="background:var(--bg-card);border:1px solid var(--border);color:var(--white);font-family:var(--font-sans);font-size:0.8rem;padding:0.5rem 1rem;width:100%;cursor:pointer;">
                  {% for value in option.values %}<option value="{{ value }}" {% if option.selected_value == value %}selected{% endif %}>{{ value }}</option>{% endfor %}
                </select>
              </div>
            {% endfor %}
          {% endif %}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          <button type="submit" name="add" class="btn-primary" style="width:100%;margin-bottom:1rem;" {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
            {% if product.selected_or_first_available_variant.available %}Add to Cart{% else %}Sold Out{% endif %}
          </button>
        {% endform %}
      </div>
    </div>
  </div>
</section>
{% schema %}{"name":"Product","settings":[]}{% endschema %}