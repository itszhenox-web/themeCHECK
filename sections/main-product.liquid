<section class="product-page">
  <div class="container">
    <div class="product-page__grid">
      <!-- Images -->
      <div class="product-page__sticky">
        {% assign featured_media = product.selected_or_first_available_variant.featured_media | default: product.featured_media %}
        <img id="main-product-img" class="product-main-img" src="{{ featured_media | img_url: '1000x' }}" alt="{{ featured_media.alt | escape }}">
        {% if product.media.size > 1 %}
        <div class="product-thumbs">
          {% for media in product.media %}
            <button class="product-thumb" data-src="{{ media | img_url: '1000x' }}">
              <img src="{{ media | img_url: '200x' }}" alt="">
            </button>
          {% endfor %}
        </div>
        {% endif %}
      </div>
      <!-- Info -->
      <div>
        <p class="product-info__breadcrumb">Shop / {{ product.type }} / {{ product.title }}</p>
        {% if product.type != blank %}<p class="product-info__type">{{ product.type }}</p>{% endif %}
        <h1 class="product-info__title">{{ product.title }}</h1>
        {% if product.metafields.custom.subtitle != blank %}
          <p class="product-info__subtitle">"{{ product.metafields.custom.subtitle }}"</p>
        {% endif %}
        <div class="product-info__stars">
          {% for i in (1..5) %}<svg width="12" height="12" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" fill="currentColor"/></svg>{% endfor %}
          <span>4.9 (2,847 reviews)</span>
        </div>
        <div class="product-divider"></div>
        <div class="product-info__price">
          <span class="product-info__price-current">{{ product.price | money }}</span>
          {% if product.compare_at_price > product.price %}
            <span class="product-info__price-old">{{ product.compare_at_price | money }}</span>
            <span class="product-info__price-save">Save {{ product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round }}%</span>
          {% endif %}
        </div>
        <div class="product-divider"></div>
        {% form 'product', product %}
          {% if product.has_only_default_variant == false %}
            {% for option in product.options_with_values %}
              <label class="product-form__label" for="opt-{{ option.name }}">{{ option.name }}</label>
              <select class="product-form__select" id="opt-{{ option.name }}" name="options[{{ option.name }}]">
                {% for value in option.values %}
                  <option value="{{ value }}" {% if option.selected_value == value %}selected{% endif %}>{{ value }}</option>
                {% endfor %}
              </select>
            {% endfor %}
          {% endif %}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          <div style="display:flex;gap:0.75rem;margin-bottom:0.75rem;">
            <div class="product-qty">
              <button type="button" class="product-qty__btn" id="qty-dec">&#8722;</button>
              <span class="product-qty__val" id="qty-val">1</span>
              <button type="button" class="product-qty__btn" id="qty-inc">&#43;</button>
            </div>
            <input type="hidden" name="quantity" id="qty-input" value="1">
            <button type="submit" name="add" class="btn-primary" style="flex:1;" {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
              {% if product.selected_or_first_available_variant.available %}Add to Cart{% else %}Sold Out{% endif %}
            </button>
          </div>
        {% endform %}
        <div class="product-urgency">
          <span class="product-urgency__dot"></span>
          <p>Current batch: <span>{{ section.settings.stock_text | default: '12 sets' }}</span> remaining for next-day dispatch</p>
        </div>
        <div class="product-trust">
          <div class="product-trust__item">
            <svg class="product-trust__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            <p>Free Shipping</p>
          </div>
          <div class="product-trust__item">
            <svg class="product-trust__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.51"/></svg>
            <p>30-Day Returns</p>
          </div>
          <div class="product-trust__item">
            <svg class="product-trust__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <p>Secure Checkout</p>
          </div>
        </div>
        <div class="product-divider"></div>
        <div class="product-desc">{{ product.description }}</div>
      </div>
    </div>
  </div>
</section>
{% schema %}{"name":"Product","settings":[{"type":"text","id":"stock_text","label":"Stock Urgency Text","default":"12 sets"}]}{% endschema %}