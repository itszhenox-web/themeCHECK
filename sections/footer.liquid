<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <div>
        <p class="footer__brand-name">Radioactive Love</p>
        <p style="font-family:var(--font-sans);font-size:0.75rem;color:var(--fg-muted);line-height:1.7;max-width:20rem;">For the love that transcends distance.</p>
      </div>
      <div>
        <p style="font-family:var(--font-sans);font-size:0.6rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--fg-muted);margin-bottom:1.25rem;">Navigate</p>
        <div class="footer__links">
          <a href="{{ routes.root_url }}">Home</a>
          <a href="{{ routes.collections['all'].url | default: '/collections/all' }}">Shop</a>
          <a href="/pages/story">Our Story</a>
          <a href="/pages/reviews">Reviews</a>
          <a href="/pages/policies">Policies</a>
        </div>
      </div>
      <div>
        <p style="font-family:var(--font-sans);font-size:0.6rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--fg-muted);margin-bottom:1.25rem;">Promise</p>
        <div style="display:flex;flex-direction:column;gap:0.75rem;color:var(--fg-muted);font-family:var(--font-sans);font-size:0.75rem;">
          <span>Free worldwide shipping</span>
          <span>30-day returns</span>
          <span>Secure checkout</span>
          <span>Ships in 24 hours</span>
        </div>
      </div>
    </div>
    <div class="footer__bottom">
      <p class="footer__copy">&copy; {{ 'now' | date: '%Y' }} Radioactive Love. All rights reserved.</p>
      <p class="footer__copy">Made with <span style="color:var(--glow);">&hearts;</span> for long distance love</p>
    </div>
  </div>
</footer>
{% schema %}{"name":"Footer","settings":[]}{% endschema %}