<footer class="footer">
  <div class="footer__glow"></div>
  <div class="container" style="position:relative;">
    <div class="footer__grid">
      <div>
        <p class="footer__brand-name">Radioactive <span>Love</span></p>
        <p class="footer__tagline">For the love that transcends distance. Every piece carries the invisible energy of your bond.</p>
      </div>
      <div>
        <p class="footer__col-title">Navigate</p>
        <div class="footer__links">
          <a href="{{ routes.root_url }}">Home</a>
          <a href="/collections/all">All Products</a>
          <a href="/collections/mini-gifts-charms">Mini Gifts &amp; Charms</a>
          <a href="/collections/jewelry-accessories">Jewelry &amp; Accessories</a>
          <a href="/pages/story">Our Story</a>
          <a href="/pages/reviews">Reviews</a>
          <a href="/pages/policies">Policies</a>
        </div>
      </div>
      <div>
        <p class="footer__col-title">Our Promise</p>
        <div class="footer__promise">
          <span>Free worldwide shipping</span>
          <span>30-day returns</span>
          <span>Secure checkout</span>
          <span>Ships in 24 hours</span>
        </div>
      </div>
    </div>
    <div class="footer__bottom">
      <p class="footer__copy">&copy; {{ 'now' | date: '%Y' }} Radioactive Love. All rights reserved.</p>
      <p class="footer__copy">Made with <span>&hearts;</span> for long-distance love</p>
    </div>
  </div>
</footer>
{% schema %}{"name":"Footer","settings":[]}{% endschema %}