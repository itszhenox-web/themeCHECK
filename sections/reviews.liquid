<section class="reviews-section">
  <div class="container">
    <div class="section-header">
      <p class="eyebrow">{{ section.settings.eyebrow | default: '— Real Love Stories' }}</p>
      <h2 class="section-title">{{ section.settings.title | default: 'What Our Couples Say' }}</h2>
    </div>
    <div class="reviews-grid">
      {%- for block in section.blocks -%}
        <div class="review-card" {{ block.shopify_attributes }}>
          <div class="review-stars">★★★★★</div>
          <p class="review-text">"{{ block.settings.text }}"</p>
          <div class="review-footer">
            <div>
              <p class="review-author">{{ block.settings.author }}</p>
              <p class="review-location">{{ block.settings.location }}</p>
            </div>
            <span class="review-verified">✓ Verified</span>
          </div>
        </div>
      {%- endfor -%}
    </div>
    <div class="reviews-app-placeholder" id="shopify-product-reviews"></div>
  </div>
</section>
{% schema %}
{
  "name": "Reviews",
  "blocks": [{"type":"review","name":"Review","settings":[
    {"type":"textarea","id":"text","label":"Review text","default":"These bracelets changed everything for us. I look at my wrist and feel him right there with me."},
    {"type":"text","id":"author","label":"Author name","default":"Sarah M."},
    {"type":"text","id":"location","label":"Location","default":"New York ↔ London"}
  ]}],
  "settings": [
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"— Real Love Stories"},
    {"type":"text","id":"title","label":"Title","default":"What Our Couples Say"}
  ],
  "presets": [{"name":"Reviews","blocks":[
    {"type":"review","settings":{"text":"We've been long distance for 2 years. These bracelets make me feel like he's right here with me every single day.","author":"Sarah & Marcus","location":"New York ↔ London"}},
    {"type":"review","settings":{"text":"I bought this as a birthday gift for my boyfriend. He literally cried. Best purchase I've ever made.","author":"Emma J.","location":"Portland, OR"}},
    {"type":"review","settings":{"text":"13,000 miles apart but these close the gap. We never take them off. It's our silent way of saying I love you.","author":"Alex & Jordan","location":"Toronto ↔ Melbourne"}}
  ]}]
}
{% endschema %}