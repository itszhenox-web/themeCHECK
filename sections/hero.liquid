<section class="hero">
  <div class="hero-content">
    <h1 class="hero-headline">Stay Connected, No Matter the Distance</h1>
    <p class="hero-subheading">{{ section.settings.hero_subheading }}</p>
    <a href="{% if section.settings.featured_product %}{{ section.settings.featured_product.url }}{% else %}{{ '/collections/all' }}{% endif %}" class="btn btn-primary btn-large">
      Explore Now
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "product",
      "id": "featured_product",
      "label": "Featured Product"
    },
    {
      "type": "richtext",
      "id": "hero_subheading",
      "label": "Subheading",
      "default": "<p>A meaningful bracelet that keeps you close, even when you're apart</p>"
    }
  ]
}
{% endschema %}