<section class="hero">
  <div class="hero-bg">
    {%- if section.settings.hero_image != blank -%}
      <img src="{{ section.settings.hero_image | img_url: '2000x' }}" alt="Hero" loading="eager" fetchpriority="high">
    {%- else -%}
      <div class="hero-bg-fallback"></div>
    {%- endif -%}
    <div class="hero-overlay"></div>
  </div>
  <div class="hero-glow"></div>
  <div class="container">
    <div class="hero-content">
      <p class="eyebrow">{{ section.settings.eyebrow | default: '— The Connection Bracelet' }}</p>
      <h1 class="hero-title">{{ section.settings.headline | default: 'Stay Connected,<br><em>No Matter the Distance.</em>' }}</h1>
      <p class="hero-sub">{{ section.settings.subheadline | default: 'A meaningful bracelet that keeps you close, even when you're apart. Worn by 50,000+ couples worldwide.' }}</p>
      <div class="hero-actions">
        <a href="{{ section.settings.cta_url | default: routes.collections_url }}" class="btn btn-primary btn-lg">
          {{ section.settings.cta_text | default: 'Shop the Collection' }}
        </a>
        {%- if section.settings.secondary_cta_text != blank -%}
        <a href="{{ section.settings.secondary_cta_url | default: '#story' }}" class="btn btn-ghost">
          {{ section.settings.secondary_cta_text }}
        </a>
        {%- endif -%}
      </div>
      <div class="hero-social-proof">
        <div class="hero-stars">★★★★★</div>
        <span>Loved by <strong>50,000+</strong> couples</span>
      </div>
    </div>
  </div>
  <div class="hero-scroll-cue"><div class="hero-scroll-line"></div></div>
</section>
{% schema %}
{
  "name": "Hero",
  "settings": [
    {"type":"image_picker","id":"hero_image","label":"Hero background image"},
    {"type":"text","id":"eyebrow","label":"Eyebrow text","default":"— The Connection Bracelet"},
    {"type":"text","id":"headline","label":"Headline","default":"Stay Connected, No Matter the Distance."},
    {"type":"textarea","id":"subheadline","label":"Subheadline","default":"A meaningful bracelet that keeps you close, even when you're apart."},
    {"type":"text","id":"cta_text","label":"Primary CTA text","default":"Shop the Collection"},
    {"type":"url","id":"cta_url","label":"Primary CTA URL"},
    {"type":"text","id":"secondary_cta_text","label":"Secondary CTA text"},
    {"type":"url","id":"secondary_cta_url","label":"Secondary CTA URL"}
  ]
}
{% endschema %}