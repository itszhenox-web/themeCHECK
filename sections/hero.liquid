<section class="hero">
  <div class="hero__bg">
    {% if section.settings.hero_image != blank %}
      <img src="{{ section.settings.hero_image | img_url: '1920x' }}" alt="Hero" loading="eager">
    {% else %}
      <div style="width:100%;height:100%;background:linear-gradient(135deg,#1a0000,#0a0a0a);"></div>
    {% endif %}
    <div class="hero__overlay"></div>
  </div>
  <div class="hero__glow"></div>
  <div class="hero__content container">
    <div style="max-width:40rem;">
      <p class="hero__eyebrow">{{ section.settings.eyebrow | default: 'The long-distance connection bracelet' }}</p>
      <h1 class="hero__title">
        {{ section.settings.headline_line1 | default: 'Distance' }}<br>
        <span style="font-style:italic;color:rgba(209,209,209,0.7);">{{ section.settings.headline_line2 | default: 'is a Myth.' }}</span>
      </h1>
      <p class="hero__subtitle">{{ section.settings.subtitle | default: 'Every piece carries the invisible energy of your connection.' }}</p>
      <a href="{{ section.settings.cta_url | default: '/collections/all' }}" style="display:inline-flex;align-items:center;gap:1rem;">
        <span style="font-family:var(--font-sans);font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--white);">{{ section.settings.cta_text | default: 'Discover the Bond' }}</span>
      </a>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Hero",
  "settings": [
    {"type":"image_picker","id":"hero_image","label":"Hero Image"},
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"The long-distance connection bracelet"},
    {"type":"text","id":"headline_line1","label":"Headline Line 1","default":"Distance"},
    {"type":"text","id":"headline_line2","label":"Headline Line 2","default":"is a Myth."},
    {"type":"textarea","id":"subtitle","label":"Subtitle"},
    {"type":"text","id":"cta_text","label":"CTA Text","default":"Discover the Bond"},
    {"type":"url","id":"cta_url","label":"CTA URL"}
  ]
}
{% endschema %}