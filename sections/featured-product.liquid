<section class="featured-product">
  {% if section.settings.product != blank %}
    {% assign featured = section.settings.product %}
    <div class="featured-product-container">
      <div class="featured-image">
        <img src="{{ featured.featured_image | img_url: '500x500' }}" alt="{{ featured.featured_image.alt }}">
      </div>
      <div class="featured-product-content">
        <h2>{{ featured.title }}</h2>
        <p class="featured-price">{{ featured.price | money }}</p>
        <p>{{ featured.description | strip_html | truncatewords: 30 }}</p>
        <a href="{{ featured.url }}" class="btn btn-primary">View Product</a>
      </div>
    </div>
  {% endif %}
</section>
{% schema %}{"name":"Featured Product","settings":[{"type":"product","id":"product","label":"Product"}]}{% endschema %}